class Bike:
    def __init__(self):
        global bikeMass, riderMass
        self.pos = 0
        self.vel = 0
        self.acc = 0
        self.mass = bikeMass + riderMass
        self.kineticE = 0
        self.potentialE = 0
        self.heatE = 0
        self.crankRad = 0.17
        self.wheelRad = 0.3
        self.frontSprocketRad = 0.03
        self.backSprocketRad = 0.05
        self.brakeForce = 0
        self.omega = 0
        self.flipangle = 0

    
    def frontFlip(self):
        global Nback
#        print('Nback: ' + str(Nback))
        return Nback <= 0
        
    def backFlip(self):
        global Nfront
#        print('Nfront: ' + str(Nfront))
        return Nfront <= 0
    
    def skid(self):
        if(frontBrakeForce > staticFricGW * Nfront):
            return True
        if(backBrakeForce > staticFricGW * Nback):
            return True
        return False
    
    
    def calculateAcc(self):
        global theta, frontBrakeForce, backBrakeForce, pedalsForce, kineticFricGW, staticFricGW, Nfront, Nback
        g = 9.81
        m = self.mass
    
        COMX = (riderMass * seatX + bikeMass * bikeCOMX) / (bikeMass + riderMass)
        backToCOM = COMX - backWheelX
        wheelbase = frontWheelX - backWheelX
    
        forceGround = pedalsForce * (self.backSprocketRad * self.crankRad) / (self.wheelRad * self.frontSprocketRad)
        gravity_parallel = -g * sin(theta)
        gravity_perpen = g * cos(theta)
        
        Nf = m * gravity_perpen * 0.5
        Nb = m * gravity_perpen * 0.5
        acc = 0

        for i in range(5):
            A = (m * g * cos(theta) * backToCOM - m * g * sin(theta) * COMY) / wheelbase
            B = m * COMY / wheelbase
            Nf = max(A - B * (acc - gravity_parallel), 0)
            Nb = max(m * g * cos(theta) - Nf, 0)
            maxFront = staticFricGW * Nf
            maxBack = staticFricGW * Nb
            appliedFront = min(frontBrakeForce, maxFront)
            appliedBack = min(backBrakeForce, maxBack)
            brakeDir = 0
            if self.vel > 1e-2:
                brakeDir = -1
            elif self.vel < 1e-2:
                brakeDir = 1
            brakeForce = brakeDir * (appliedFront + appliedBack)
            acc = (brakeForce + forceGround) / m + gravity_parallel
        self.acc = acc
        self.brakeForce = brakeForce
        Nfront = Nf
        Nback = Nb
        if self.skid():
            if self.acc > 0:
                self.acc -= kineticFricGW * Nback / m
            elif self.acc < 0:
                self.acc += kineticFricGW * Nback / m
    
    def calculateVel(self):
        global deltaT
        self.vel += self.acc * deltaT
        if (abs(self.vel) < 1e-2):
            self.vel = 0
        
    def calculatePos(self):
        global deltaT
        self.pos += self.vel * deltaT
    
    def calculateEnergies(self):
        global deltaT, kineticFricGW, theta, Nback
        deltaH = self.vel * deltaT * sin(theta)
        self.kineticE = 0.5 * self.mass * self.vel * self.vel
        self.potentialE += deltaH * self.mass * 9.81
        if(self.skid()):
            self.heatE += kineticFricGW * (max(Nback, 0) + max(Nfront, 0)) * abs(self.vel) * deltaT
            
    def rotatewheels(self):
        global backwheelparts, frontwheelparts
        for part in backwheelparts:
            part.rotate(axis=vec(0,0,1), angle=((-self.vel/self.wheelRad)*deltaT), origin=wheel1.pos)
        for part in frontwheelparts:
            part.rotate(axis=vec(0,0,1), angle=((-self.vel/self.wheelRad)*deltaT), origin=wheel2.pos)
            
    def flipbike(self):
        global Nfront, Nback, deltaT, theta, running
        g = 9.81
        m = self.mass
        COMX = (riderMass * seatX + bikeMass * bikeCOMX) / (bikeMass + riderMass)
        wheelbase = frontWheelX - backWheelX
        torqueback = m * g * (COMX - backWheelX) * cos(self.flipangle)
        torquefront = -m * g * (frontWheelX - COMX) * cos(self.flipangle)
        if Nback <= 0 or Nfront <= 0:
            
            rampAngleSlider.disabled = True
            riderMassSlider.disabled = True
            bikeMassSlider.disabled = True
            backBrakeForceSlider.disabled = True
            frontBrakeForceSlider.disabled = True
            pedalsForceSlider.disabled = True
            staticFricGWSlider.disabled = True
            kineticFricGWSlider.disabled = True
        if Nback <= 0:
            r = sqrt((frontWheelX - COMX)**2 + COMY**2) / 10
            I = m * r**2
            alpha = torquefront / I
            pivotpoint = bikeObject.pos + wheel2.pos
        elif Nfront <= 0:
            r = sqrt((COMX - backWheelX)**2 + COMY**2) / 10
            I = m * r**2
            alpha = torqueback / I 
            pivotpoint = bikeObject.pos + wheel1.pos
        else:
            return
        self.omega += alpha * deltaT
        self.flipangle += self.omega * deltaT
        if(abs(self.flipangle) >= (pi - 1)):
            running = False
            
        bikeObject.rotate(axis=vec(0,0,1), angle=self.omega * deltaT, origin = pivotpoint)     


