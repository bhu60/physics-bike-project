        if(Nback <= 0 or Nfront <= 0):
            bike.acc = 0
            bike.vel = 0
        else:
            bike.calculateAcc()
            bike.calculateVel()
    bike.calculatePos()
    bike.calculateEnergies()
    bike.rotatewheels()
    bike.flipbike()
    bikeObject.axis = vec(cos(theta + bike.flipangle), sin(theta + bike.flipangle), 0)
    bikeObject.pos = vec(bike.pos * 10 * cos(theta), bike.pos * 10 * sin(theta), 0)
    dir = vec(cos(theta), sin(theta), 0)
    perpendicular = vec(-sin(theta), cos(theta), 0)
    rampLine.axis = dir
    rampLine.pos = vec(0,0,0) - 4 * perpendicular
    for j in range(len(rampStripes)):
        rampStripes[j].axis = dir
        rampStripes[j].pos = (j - 1000) * 10 * dir - 3.7*perpendicular
    ticks += 1
    
    gPosCurve.plot(ticks / 10, bike.pos)
    gVelCurve.plot(ticks / 10, bike.vel)
    gAccCurve.plot(ticks / 10, bike.acc)
    gKineticCurve.plot(ticks / 10, bike.kineticE)
    gPotentialCurve.plot(ticks / 10, bike.potentialE)
    gThermalCurve.plot(ticks / 10, bike.heatE)
    firstRun = False
    justReset = False
        
