rampAngle = 0
weight = 0
breaksForce = 0
pedalsForce = 0
staticFricGW = 0
kineticFricGW = 0

scene.caption = "\nRamp Angle: "
def setRampAngle(rampAngleSlider):
    global rampAngle
    rampAngleText.text = '{:1.1f}'.format(rampAngleSlider.value)
    rampAngle = rampAngleSlider.value
rampAngleSlider = slider(bind = setRampAngle, min=-90, max=90, step = 1, value = 0)
rampAngleText = wtext(text='{:1.1f}'.format(rampAngleSlider.value))
scene.append_to_caption(' degrees')


scene.append_to_caption('\nWeight: ')
def setWeight(weightSlider):
    global weight
    weightText.text = '{:1.1f}'.format(weightSlider.value)
    weight = weightSlider.value
weightSlider = slider(bind = setWeight, min=0, max=10000, step = 5, value = 0)
weightText = wtext(text='{:1.1f}'.format(weightSlider.value))
scene.append_to_caption(' Newtons')

scene.append_to_caption('\nForce on Breaks: ')
def setBreaksForce(breaksForceSlider):
    global breaksForce
    breaksForceText.text = '{:1.1f}'.format(breaksForceSlider.value)
    breaksForce = breaksForceSlider.value
breaksForceSlider = slider(bind = setBreaksForce, min=0, max=10000, step = 5, value = 0)
breaksForceText = wtext(text='{:1.1f}'.format(breaksForceSlider.value))
scene.append_to_caption(' Newtons')


scene.append_to_caption('\nForce on Pedals: ')
def setpedalsForce(pedalsForceSlider):
    global pedalsForce
    pedalsForceText.text = '{:1.1f}'.format(pedalsForceSlider.value)
    pedalsForce = pedalsForceSlider.value
pedalsForceSlider = slider(bind = setpedalsForce, min=0, max=10000, step = 5, value = 0)
pedalsForceText = wtext(text='{:1.1f}'.format(pedalsForceSlider.value))
scene.append_to_caption(' Newtons')

scene.append_to_caption('\nStatic Friction (Ground, Wheel): ')
def setStaticFricGW(staticFricGWSlider):
    global staticFricGW
    staticFricGWText.text = '{:1.2f}'.format(staticFricGWSlider.value)
    staticFricGW = staticFricGWSlider.value
staticFricGWSlider = slider(bind = setStaticFricGW, min=0, max=1, step = 0.01, value = 0)
staticFricGWText = wtext(text='{:1.2f}'.format(staticFricGWSlider.value))

scene.append_to_caption('\nKinetic Friction (Ground, Wheel): ')
def setKineticFricGW(kineticFricGWSlider):
    global kineticFricGW
    kineticFricGWText.text = '{:1.2f}'.format(kineticFricGWSlider.value)
    kineticFricGW = kineticFricGWSlider.value
kineticFricGWSlider = slider(bind = setKineticFricGW, min=0, max=1, step = 0.01, value = 0)
kineticFricGWText = wtext(text='{:1.2f}'.format(kineticFricGWSlider.value))

button(bind=setWeight, text="Click to Brake", background=color.green, pos=scene.title_anchor)
